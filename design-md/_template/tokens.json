{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "brand": {
      "primary": {
        "$value": "#5677fc",
        "$type": "color",
        "description": "Main brand color for CTAs"
      },
      "primary-light": {
        "$value": "#5c8dff",
        "$type": "color",
        "description": "Primary button gradient end"
      },
      "success": {
        "$value": "#19be6b",
        "$type": "color",
        "description": "Success states, positive actions"
      },
      "warning": {
        "$value": "#ff7900",
        "$type": "color",
        "description": "Warning states"
      },
      "error": {
        "$value": "#EB0909",
        "$type": "color",
        "description": "Error states, destructive actions"
      }
    },
    "text": {
      "title": {
        "$value": "#333333",
        "$type": "color",
        "description": "Headlines, important text"
      },
      "body": {
        "$value": "#333333",
        "$type": "color",
        "description": "Main content text"
      },
      "secondary": {
        "$value": "#555555",
        "$type": "color",
        "description": "Secondary content"
      },
      "muted": {
        "$value": "#999999",
        "$type": "color",
        "description": "Hints, timestamps, placeholders"
      },
      "placeholder": {
        "$value": "#bfbfbf",
        "$type": "color",
        "description": "Input placeholders"
      },
      "disabled": {
        "$value": "#c0c0c0",
        "$type": "color",
        "description": "Disabled text"
      }
    },
    "background": {
      "page": {
        "$value": "#fafafa",
        "$type": "color",
        "description": "Page background"
      },
      "card": {
        "$value": "#ffffff",
        "$type": "color",
        "description": "Card, elevated surfaces"
      },
      "hover": {
        "$value": "#f1f1f1",
        "$type": "color",
        "description": "Touch/hover state"
      },
      "mask": {
        "$value": "rgba(0,0,0,0.4)",
        "$type": "color",
        "description": "Modal overlay"
      }
    },
    "border": {
      "default": {
        "$value": "#eaeef1",
        "$type": "color",
        "description": "Default borders"
      },
      "light": {
        "$value": "#f5f5f5",
        "$type": "color",
        "description": "Subtle dividers"
      }
    }
  },
  "typography": {
    "fontFamily": {
      "primary": {
        "$value": "-apple-system-font, Helvetica Neue, Helvetica, sans-serif",
        "$type": "fontFamily"
      },
      "monospace": {
        "$value": "SF Mono, Menlo, Courier, monospace",
        "$type": "fontFamily"
      }
    },
    "fontSize": {
      "display": {
        "$value": "40rpx",
        "$type": "dimension"
      },
      "h1": {
        "$value": "36rpx",
        "$type": "dimension"
      },
      "h2": {
        "$value": "32rpx",
        "$type": "dimension"
      },
      "h3": {
        "$value": "28rpx",
        "$type": "dimension"
      },
      "body": {
        "$value": "28rpx",
        "$type": "dimension"
      },
      "bodySmall": {
        "$value": "24rpx",
        "$type": "dimension"
      },
      "caption": {
        "$value": "24rpx",
        "$type": "dimension"
      },
      "overline": {
        "$value": "20rpx",
        "$type": "dimension"
      }
    },
    "lineHeight": {
      "tight": {
        "$value": "1.2",
        "$type": "number"
      },
      "normal": {
        "$value": "1.5",
        "$type": "number"
      },
      "relaxed": {
        "$value": "1.6",
        "$type": "number"
      }
    },
    "fontWeight": {
      "regular": {
        "$value": "400",
        "$type": "fontWeight"
      },
      "medium": {
        "$value": "500",
        "$type": "fontWeight"
      },
      "semibold": {
        "$value": "600",
        "$type": "fontWeight"
      }
    }
  },
  "spacing": {
    "xs": {
      "$value": "8rpx",
      "$type": "dimension"
    },
    "sm": {
      "$value": "16rpx",
      "$type": "dimension"
    },
    "base": {
      "$value": "20rpx",
      "$type": "dimension"
    },
    "lg": {
      "$value": "24rpx",
      "$type": "dimension"
    },
    "xl": {
      "$value": "32rpx",
      "$type": "dimension"
    },
    "xxl": {
      "$value": "48rpx",
      "$type": "dimension"
    }
  },
  "borderRadius": {
    "sm": {
      "$value": "4rpx",
      "$type": "dimension"
    },
    "base": {
      "$value": "6rpx",
      "$type": "dimension"
    },
    "lg": {
      "$value": "12rpx",
      "$type": "dimension"
    },
    "xl": {
      "$value": "24rpx",
      "$type": "dimension"
    },
    "full": {
      "$value": "9999rpx",
      "$type": "dimension"
    }
  },
  "shadow": {
    "card": {
      "$value": "0 2rpx 8rpx rgba(0,0,0,0.08)",
      "$type": "shadow",
      "description": "Default card shadow"
    },
    "elevated": {
      "$value": "0 4rpx 16rpx rgba(0,0,0,0.12)",
      "$type": "shadow",
      "description": "Floating elements"
    },
    "modal": {
      "$value": "0 8rpx 32rpx rgba(0,0,0,0.16)",
      "$type": "shadow",
      "description": "Dialogs, modals"
    }
  },
  "component": {
    "button": {
      "primary": {
        "height": "90rpx",
        "borderRadius": "45rpx",
        "fontSize": "36rpx",
        "background": "linear-gradient(-90deg, #5677fc, #5c8dff)",
        "color": "#ffffff"
      },
      "secondary": {
        "height": "88rpx",
        "borderRadius": "44rpx",
        "fontSize": "32rpx",
        "background": "#ffffff",
        "border": "1rpx solid #eaeef1",
        "color": "#333333"
      },
      "disabled": {
        "opacity": 0.3
      }
    },
    "input": {
      "height": "96rpx",
      "borderRadius": "6rpx",
      "paddingHorizontal": "24rpx",
      "border": "1rpx solid #eaeef1",
      "fontSize": "28rpx"
    },
    "card": {
      "borderRadius": "12rpx",
      "padding": "24rpx",
      "shadow": "0 2rpx 8rpx rgba(0,0,0,0.08)"
    },
    "listCell": {
      "paddingVertical": "24rpx",
      "paddingHorizontal": "30rpx",
      "borderBottom": "1rpx solid #eaeef1"
    },
    "tabbar": {
      "height": "100rpx",
      "iconSize": "52rpx",
      "selectedColor": "#5677fc",
      "unselectedColor": "#999999"
    }
  }
}
